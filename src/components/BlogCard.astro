---
import type { CollectionEntry } from "astro:content";
import T from "@/components/T.astro";
import type { TranslationKey } from "@/i18n";

interface Props {
  post: CollectionEntry<"posts">;
  index?: number;
}

const { post, index = 0 } = Astro.props;
const baseUrl = import.meta.env.BASE_URL.replace(/\/?$/, "/");

const slug = post.id.replace(/\.mdx?$/, "");
const url = `${baseUrl}blog/${slug}`;

const formatDate = (d: Date) =>
  d.toLocaleDateString("zh-TW", { year: "numeric", month: "long", day: "numeric" });

const categoryKey = (`category.${post.data.category}` as unknown) as TranslationKey;
---

<a href={url} class="group block" style={`animation-delay: ${index * 100}ms`}>
  <article
    class="animate-fade-up bg-card rounded-xl overflow-hidden border border-border/50 hover:border-border transition-all duration-500 hover:-translate-y-1"
  >
    {
      post.data.coverImage && (
        <div class="aspect-[16/10] overflow-hidden bg-secondary">
          <img
            src={post.data.coverImage}
            alt={post.data.title}
            loading="lazy"
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
          />
        </div>
      )
    }
    <div class="p-6 space-y-3">
      <div class="flex items-center gap-3 text-xs">
        <span class="px-2.5 py-1 bg-secondary rounded-full text-secondary-foreground font-medium">
          <T k={categoryKey} />
        </span>
        {post.data.readTime && (
          <span class="text-muted-foreground">{post.data.readTime}</span>
        )}
      </div>

      <h3 class="font-display text-xl font-medium leading-snug group-hover:text-muted-foreground transition-colors">
        {post.data.title}
      </h3>

      {
        post.data.excerpt && (
          <p class="text-muted-foreground text-sm line-clamp-2 leading-relaxed">
            {post.data.excerpt}
          </p>
        )
      }

      <div class="flex items-center justify-between pt-2 text-xs">
        <div class="flex flex-wrap gap-2">
          {
            post.data.tags?.slice(0, 3).map((tag) => (
              <span class="text-muted-foreground">#{tag}</span>
            ))
          }
        </div>
        <span class="text-muted-foreground">{formatDate(post.data.publishedAt)}</span>
      </div>
    </div>
  </article>
</a>
