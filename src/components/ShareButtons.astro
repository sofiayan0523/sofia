---
import T from "@/components/T.astro";
import { getTranslations, DEFAULT_LANG } from "@/i18n";

interface Props {
  title: string;
}

const { title } = Astro.props;
const t = getTranslations(DEFAULT_LANG);
---

<div class="space-y-3">
  <p class="text-xs uppercase tracking-wider text-muted-foreground font-display font-medium">
    <T k="share.title" />
  </p>
  <div class="flex items-center gap-2 flex-wrap" id="share-buttons-container">
    {/* X (Twitter) */}
    <a
      href=""
      id="share-x"
      target="_blank"
      rel="noopener noreferrer"
      class="p-2 rounded-lg border border-border bg-card text-foreground hover:bg-[#1A1A1A] hover:text-white hover:border-[#1A1A1A] transition-all flex items-center justify-center"
      title={t("share.twitter")}
      data-title={title}
    >
      <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
      </svg>
    </a>

    {/* Facebook */}
    <a
      href=""
      id="share-fb"
      target="_blank"
      rel="noopener noreferrer"
      class="p-2 rounded-lg border border-border bg-card text-foreground hover:bg-[#2E52A0] hover:text-white hover:border-[#2E52A0] transition-all flex items-center justify-center"
      title={t("share.facebook")}
    >
      <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M22 12c0-5.52-4.48-10-10-10S2 6.48 2 12c0 4.84 3.44 8.87 8 9.8V15H8v-3h2V9.5C10 7.57 11.57 6 13.5 6H16v3h-2c-.55 0-1 .45-1 1v2h3v3h-3v6.95c4.56-.93 8-4.96 8-9.75z" />
      </svg>
    </a>

    {/* LinkedIn */}
    <a
      href=""
      id="share-linkedin"
      target="_blank"
      rel="noopener noreferrer"
      class="p-2 rounded-lg border border-border bg-card text-foreground hover:bg-[#0077b5] hover:text-white hover:border-[#0077b5] transition-all flex items-center justify-center"
      title={t("share.linkedin")}
    >
      <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" />
      </svg>
    </a>

    {/* LINE */}
    <a
      href=""
      id="share-line"
      target="_blank"
      rel="noopener noreferrer"
      class="p-2 rounded-lg border border-border bg-card text-foreground hover:bg-[#06C755] hover:text-white hover:border-[#06C755] transition-all flex items-center justify-center"
      title={t("share.line")}
    >
      {/* Custom LINE icon SVG */}
      <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M24 10.304c0-5.369-5.383-9.738-12-9.738-6.616 0-12 4.369-12 9.738 0 4.814 4.269 8.843 10.06 9.588.39.084.922.258 1.058.592.121.306.079.785.038 1.094l-.165 1.002c-.05.303-.242 1.187 1.042.647 1.284-.54 6.934-4.085 9.461-6.99 1.954-2.128 2.506-3.993 2.506-5.933zm-15.117 2.803h-2.311a.434.434 0 0 1-.433-.434v-4.32a.434.434 0 0 1 .433-.434h.341c.24 0 .433.194.433.434v3.545h1.537c.24 0 .434.194.434.434v.378a.434.434 0 0 1-.434.433zm3.178-.434a.434.434 0 0 1-.434.434h-.341a.434.434 0 0 1-.434-.434v-4.32a.434.434 0 0 1 .434-.434h.341c.24 0 .434.194.434.434v4.32zm4.364 0a.434.434 0 0 1-.433.434h-.328a.433.433 0 0 1-.39-.247l-1.848-2.61v2.423a.434.434 0 0 1-.434.434h-.341a.434.434 0 0 1-.434-.434v-4.32a.434.434 0 0 1 .434-.434h.34c.163 0 .31.092.383.24l1.83 2.585v-2.391a.434.434 0 0 1 .434-.434h.341c.24 0 .433.194.433.434v4.321zm4.276-2.45h-1.523v.975h1.523c.24 0 .433.194.433.434v.378a.434.434 0 0 1-.433.434h-1.523v.975h1.523c.24 0 .433.194.433.434v.378a.434.434 0 0 1-.433.434h-2.297a.434.434 0 0 1-.434-.434v-4.32a.434.434 0 0 1 .434-.434h2.297c.24 0 .433.194.433.434v.378a.434.434 0 0 1-.433.434z" />
      </svg>
    </a>

    {/* Copy Link */}
    <button
      id="copy-link-btn"
      class="p-2 rounded-lg border border-border bg-card text-foreground hover:bg-[#7F9C7E]/10 hover:text-[#7F9C7E] hover:border-[#7F9C7E]/40 transition-all flex items-center justify-center gap-1.5 text-xs font-medium"
      title={t("share.copy")}
      data-copied-text={t("share.copied")}
      data-original-text={t("share.copy")}
    >
      <svg class="w-4 h-4 fill-none stroke-current" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71" />
        <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71" />
      </svg>
      <span id="copy-text"><T k="share.copy" /></span>
    </button>
  </div>
</div>

<script is:inline>
  // Dynamically set share URLs using the current page's URL
  function setupShareUrls() {
    const currentUrl = encodeURIComponent(window.location.href);
    const container = document.getElementById("share-buttons-container");
    if (!container) return;

    const btnX = container.querySelector("#share-x");
    if (btnX) {
      const postTitle = encodeURIComponent(btnX.getAttribute("data-title") || "");
      btnX.href = `https://twitter.com/intent/tweet?text=${postTitle}&url=${currentUrl}`;
    }

    const btnFb = container.querySelector("#share-fb");
    if (btnFb) {
      btnFb.href = `https://www.facebook.com/sharer/sharer.php?u=${currentUrl}`;
    }

    const btnLinkedin = container.querySelector("#share-linkedin");
    if (btnLinkedin) {
      btnLinkedin.href = `https://www.linkedin.com/sharing/share-offsite/?url=${currentUrl}`;
    }

    const btnLine = container.querySelector("#share-line");
    if (btnLine) {
      btnLine.href = `https://social-plugins.line.me/lineit/share?url=${currentUrl}`;
    }

    const btnCopy = container.querySelector("#copy-link-btn");
    if (btnCopy) {
      const copyTextEl = btnCopy.querySelector("#copy-text");
      const copiedText = btnCopy.getAttribute("data-copied-text");
      const originalText = btnCopy.getAttribute("data-original-text");
      let isCopying = false;

      btnCopy.addEventListener("click", async () => {
        if (isCopying) return;
        try {
          await navigator.clipboard.writeText(window.location.href);
          isCopying = true;
          if (copyTextEl) copyTextEl.textContent = copiedText;
          btnCopy.classList.remove("border-border", "text-foreground");
          btnCopy.classList.add("border-[#7F9C7E]", "text-[#7F9C7E]", "bg-[#7F9C7E]/10");

          setTimeout(() => {
            if (copyTextEl) copyTextEl.textContent = originalText;
            btnCopy.classList.add("border-border", "text-foreground");
            btnCopy.classList.remove("border-[#7F9C7E]", "text-[#7F9C7E]", "bg-[#7F9C7E]/10");
            isCopying = false;
          }, 2000);
        } catch (err) {
          console.error("Failed to copy link:", err);
        }
      });
    }
  }

  // Run on load and after view transitions (if any)
  setupShareUrls();
  document.addEventListener("astro:page-load", setupShareUrls);
</script>
