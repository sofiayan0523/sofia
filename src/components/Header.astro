---
import T from "@/components/T.astro";
import ThemeToggle from "@/components/ThemeToggle.tsx";
import LanguageSwitcher from "@/components/LanguageSwitcher.tsx";
import type { TranslationKey } from "@/i18n";

const baseUrl = import.meta.env.BASE_URL.replace(/\/?$/, "/");

const currentPath = Astro.url.pathname;
// Strip Astro base path (e.g. "/" or legacy "/sofia") so isActive() can match clean paths.
const basePrefix = baseUrl.replace(/\/$/, "");
const stripBase = (p: string) =>
  basePrefix && p.startsWith(basePrefix) ? p.slice(basePrefix.length) || "/" : p;
const here = stripBase(currentPath);

const navItems: { path: string; key: TranslationKey }[] = [
  { path: "/", key: "nav.home" },
  { path: "/about", key: "nav.about" },
  { path: "/blog", key: "nav.blog" },
  { path: "/career", key: "nav.career" },
  { path: "/speaker", key: "nav.speaker" },
];

const isActive = (path: string) =>
  path === "/" ? here === "/" : here === path || here.startsWith(`${path}/`);

const hrefFor = (path: string) =>
  path === "/" ? baseUrl : `${baseUrl.replace(/\/$/, "")}${path}`;
---

<header
  class="fixed top-0 left-0 right-0 z-50 bg-background/80 backdrop-blur-md border-b border-border/50"
>
  <div class="container max-w-5xl mx-auto px-6 h-16 flex items-center justify-between">
    <a
      href={baseUrl}
      class="font-display text-xl font-medium tracking-tight hover:opacity-70 transition-opacity"
    >
      Sofia Yan
    </a>

    <!-- Desktop nav -->
    <div class="hidden md:flex items-center gap-3 text-sm">
      <nav class="flex items-center gap-2">
        {
          navItems.map((item) => {
            const active = isActive(item.path);
            return (
              <a
                href={hrefFor(item.path)}
                class:list={[
                  "px-3 py-1.5 rounded-md transition-colors hover:text-foreground",
                  active ? "text-foreground font-medium" : "text-muted-foreground",
                ]}
              >
                <T k={item.key} />
              </a>
            );
          })
        }
      </nav>
      <LanguageSwitcher client:load />
      <ThemeToggle client:load />
    </div>

    <!-- Mobile controls -->
    <div class="flex items-center gap-1 md:hidden">
      <LanguageSwitcher client:load />
      <ThemeToggle client:load />
      <button
        type="button"
        id="mobile-menu-btn"
        aria-label="開啟選單"
        aria-controls="mobile-menu"
        aria-expanded="false"
        class="inline-flex items-center justify-center h-9 w-9 rounded-md text-muted-foreground hover:text-foreground hover:bg-secondary transition-colors"
      >
        <svg data-icon="open" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
        <svg data-icon="close" class="hidden" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
      </button>
    </div>
  </div>

  <!-- Mobile dropdown panel -->
  <nav
    id="mobile-menu"
    class="hidden md:hidden border-t border-border/50 bg-background/95 backdrop-blur-md"
    aria-label="行動裝置選單"
  >
    <ul class="container max-w-5xl mx-auto px-6 py-2 divide-y divide-border/50">
      {
        navItems.map((item) => {
          const active = isActive(item.path);
          return (
            <li>
              <a
                href={hrefFor(item.path)}
                aria-current={active ? "page" : undefined}
                class:list={[
                  "flex items-center justify-between py-3.5 text-base transition-colors hover:text-foreground",
                  active ? "text-foreground font-medium" : "text-muted-foreground",
                ]}
              >
                <T k={item.key} />
                {active && <span class="h-1.5 w-1.5 rounded-full bg-primary" aria-hidden="true" />}
              </a>
            </li>
          );
        })
      }
    </ul>
  </nav>
</header>

<script is:inline>
  (function () {
    const btn = document.getElementById("mobile-menu-btn");
    const menu = document.getElementById("mobile-menu");
    if (!btn || !menu) return;
    const openIcon = btn.querySelector('[data-icon="open"]');
    const closeIcon = btn.querySelector('[data-icon="close"]');

    function setOpen(open) {
      menu.classList.toggle("hidden", !open);
      btn.setAttribute("aria-expanded", open ? "true" : "false");
      btn.setAttribute("aria-label", open ? "關閉選單" : "開啟選單");
      if (openIcon) openIcon.classList.toggle("hidden", open);
      if (closeIcon) closeIcon.classList.toggle("hidden", !open);
    }

    btn.addEventListener("click", () => {
      setOpen(menu.classList.contains("hidden"));
    });

    // Close on Escape
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") setOpen(false);
    });
  })();
</script>
