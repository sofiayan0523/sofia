---
import T from "@/components/T.astro";
import ThemeToggle from "@/components/ThemeToggle.tsx";
import LanguageSwitcher from "@/components/LanguageSwitcher.tsx";
import type { TranslationKey } from "@/i18n";

const baseUrl = import.meta.env.BASE_URL.replace(/\/?$/, "/");

const currentPath = Astro.url.pathname;
// Strip Astro base path (e.g. "/" or legacy "/sofia") so isActive() can match clean paths.
const basePrefix = baseUrl.replace(/\/$/, "");
const stripBase = (p: string) =>
  basePrefix && p.startsWith(basePrefix) ? p.slice(basePrefix.length) || "/" : p;
const here = stripBase(currentPath);

const navItems: { path: string; key: TranslationKey }[] = [
  { path: "/", key: "nav.home" },
  { path: "/about", key: "nav.about" },
  { path: "/blog", key: "nav.blog" },
  { path: "/career", key: "nav.career" },
];

const isActive = (path: string) =>
  path === "/" ? here === "/" : here === path || here.startsWith(`${path}/`);
---

<header
  class="fixed top-0 left-0 right-0 z-50 bg-background/80 backdrop-blur-md border-b border-border/50"
>
  <div class="container max-w-5xl mx-auto px-6 h-16 flex items-center justify-between">
    <a
      href={baseUrl}
      class="font-display text-xl font-medium tracking-tight hover:opacity-70 transition-opacity"
    >
      Sofia Yan
    </a>

    <div class="flex items-center gap-1 md:gap-3 text-sm">
      <nav class="flex items-center gap-1 md:gap-2">
        {
          navItems.map((item) => {
            const active = isActive(item.path);
            const href = item.path === "/" ? baseUrl : `${baseUrl.replace(/\/$/, "")}${item.path}`;
            return (
              <a
                href={href}
                class:list={[
                  "px-3 py-1.5 rounded-md transition-colors hover:text-foreground",
                  active ? "text-foreground font-medium" : "text-muted-foreground",
                ]}
              >
                <T k={item.key} />
              </a>
            );
          })
        }
      </nav>
      <LanguageSwitcher client:load />
      <ThemeToggle client:load />
    </div>
  </div>
</header>
