---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import CaptureEye from "@/components/CaptureEye.astro";
import { workItems, speakingItems, mediaItems, podcastItems } from "@/data/career";
import T from "@/components/T.astro";

const baseUrl = import.meta.env.BASE_URL.replace(/\/?$/, "/");
const logoUrl = (filename: string) => `${baseUrl}images/logos/${filename}`;
---

<BaseLayout
  title="Career"
  description="演講、媒體報導、Podcast 訪談與工作經歷。了解 Sofia 在 AI、區塊鏈與數位內容驗證領域的專業歷程。"
>
  <Header />
  <main class="pt-24 pb-16">
    <div class="container max-w-5xl mx-auto px-6">
      <div class="mb-12 animate-fade-up flex flex-col md:flex-row md:items-center md:justify-between gap-6">
        <div>
          <h1 class="font-display text-2xl md:text-3xl font-medium mb-4">
            <T k="career.title" />
          </h1>
          <p class="text-muted-foreground text-lg"><T k="career.description" /></p>
        </div>
        <div class="w-48 md:w-56 rounded-xl overflow-hidden flex-shrink-0">
          <CaptureEye
            nid="bafkreia5ubvraec2kzmsgjon2kklua5fstlxs6ztbyf7i3exdy75hghgxy"
            src={`${baseUrl}images/profile/sofia-speak.jpg`}
            alt="Sofia speaking"
            imgClass="w-full h-auto"
          />
        </div>
      </div>

      <!-- Work Section -->
      <section class="mb-16">
        <div class="flex items-center gap-3 mb-8">
          <div class="w-10 h-10 rounded-lg bg-secondary flex items-center justify-center">
            <span class="text-sm" aria-hidden="true">💼</span>
          </div>
          <h2 class="font-display text-xl font-medium"><T k="career.work" /></h2>
        </div>
        <div class="grid grid-cols-2 lg:grid-cols-3 gap-4">
          {
            workItems.map((item) => (
              <a
                href={item.link}
                target="_blank"
                rel="noopener noreferrer"
                class="group relative rounded-xl bg-card border border-border overflow-hidden transition-all duration-300 hover:border-primary/30"
              >
                <div class="relative p-5 flex flex-col">
                  <div class="h-12 mb-4 flex items-center">
                    <img
                      src={logoUrl(item.logo)}
                      alt={item.title}
                      loading="lazy"
                      class="max-h-10 max-w-full object-contain filter dark:brightness-0 dark:invert opacity-70 group-hover:opacity-100 transition-opacity"
                    />
                  </div>
                  <div>
                    <h3 class="font-display text-base font-medium mb-2 group-hover:text-primary transition-colors">
                      {item.title}
                    </h3>
                    <p class="text-xs text-muted-foreground line-clamp-3 leading-relaxed">
                      {item.description}
                    </p>
                  </div>
                  <div class="flex items-center justify-end pt-2">
                    <span
                      class="text-muted-foreground opacity-0 group-hover:opacity-100 transition-opacity"
                      aria-hidden="true"
                    >
                      ↗
                    </span>
                  </div>
                </div>
              </a>
            ))
          }
        </div>
      </section>

      <div class="grid md:grid-cols-2 gap-6">
        <!-- Speaking -->
        <section class="h-full flex flex-col">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-lg bg-secondary flex items-center justify-center">
              <span class="text-sm" aria-hidden="true">🎤</span>
            </div>
            <h2 class="font-display text-xl font-medium"><T k="career.speaking" /></h2>
          </div>
          <div class="rounded-xl bg-card border border-border overflow-hidden flex-1">
            <ul class="p-5 space-y-3">
              {
                speakingItems.map((item) => (
                  <li>
                    {item.link ? (
                      <a
                        href={item.link}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="group flex items-start gap-2 text-sm text-foreground/80 hover:text-primary transition-colors"
                      >
                        <span class="text-muted-foreground mt-1">•</span>
                        <span class="flex-1">{item.title}</span>
                      </a>
                    ) : (
                      <span class="flex items-start gap-2 text-sm text-foreground/80">
                        <span class="text-muted-foreground mt-1">•</span>
                        <span class="flex-1">{item.title}</span>
                      </span>
                    )}
                  </li>
                ))
              }
            </ul>
          </div>
        </section>

        <!-- Media -->
        <section class="h-full flex flex-col">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-lg bg-secondary flex items-center justify-center">
              <span class="text-sm" aria-hidden="true">📰</span>
            </div>
            <h2 class="font-display text-xl font-medium"><T k="career.media" /></h2>
          </div>
          <div class="rounded-xl bg-card border border-border p-5 flex-1">
            <ul class="space-y-4">
              {
                mediaItems.map((item) => (
                  <li>
                    <a
                      href={item.link}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="group block"
                    >
                      <p class="text-xs text-primary/70 uppercase tracking-wider mb-1 font-medium">
                        {item.source}
                      </p>
                      <p class="text-sm text-foreground/80 group-hover:text-primary transition-colors">
                        {item.title}
                      </p>
                    </a>
                  </li>
                ))
              }
            </ul>
          </div>
        </section>
      </div>

      <!-- Podcast -->
      <section class="mt-6">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 rounded-lg bg-secondary flex items-center justify-center">
            <span class="text-sm" aria-hidden="true">🎧</span>
          </div>
          <h2 class="font-display text-xl font-medium"><T k="career.podcast" /></h2>
        </div>
        <div class="rounded-xl bg-card border border-border p-5">
          <ul class="grid md:grid-cols-2 gap-4">
            {
              podcastItems.map((item) => (
                <li>
                  <a
                    href={item.link}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="group block"
                  >
                    <p class="text-xs text-primary/70 uppercase tracking-wider mb-1 font-medium">
                      {item.source}
                    </p>
                    <p class="text-sm text-foreground/80 group-hover:text-primary transition-colors">
                      {item.title}
                    </p>
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
      </section>

      <section class="mt-16 border-t border-border pt-10 space-y-5">
        <div class="space-y-2 max-w-2xl">
          <p class="text-muted-foreground uppercase tracking-widest text-xs font-medium">
            <span data-l="zh">Speaking</span><span data-l="en">Speaking</span>
          </p>
          <h2 class="font-display text-xl md:text-2xl font-medium">
            <span data-l="zh">如果這些經驗剛好對你的團隊有用</span>
            <span data-l="en">If this field experience is useful for your team</span>
          </h2>
          <p class="text-muted-foreground leading-relaxed">
            <span data-l="zh">演講與工作坊會把這些 AI 導入、內容溯源、團隊協作的現場，整理成團隊聽得懂、也能帶回去試的版本。</span>
            <span data-l="en">Talks and workshops turn these AI adoption, content provenance, and team-operation field notes into something teams can understand and try.</span>
          </p>
        </div>
        <div class="flex flex-wrap gap-4">
          <a
            href={`${baseUrl}speaker`}
            class="inline-flex items-center gap-1 px-5 py-3 rounded-md bg-primary text-primary-foreground hover:opacity-90 transition-opacity font-medium"
          >
            <span data-l="zh">看演講主題</span><span data-l="en">See speaking topics</span>
            <span aria-hidden="true">→</span>
          </a>
          <a
            href={`${baseUrl}blog`}
            class="inline-flex items-center gap-1 px-5 py-3 rounded-md border border-border hover:bg-secondary transition-colors font-medium"
          >
            <span data-l="zh">先讀文章</span><span data-l="en">Read essays first</span>
          </a>
        </div>
      </section>
    </div>
  </main>
  <Footer />
</BaseLayout>
