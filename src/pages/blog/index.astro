---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import BlogCard from "@/components/BlogCard.astro";
import T from "@/components/T.astro";
import { getTranslations, DEFAULT_LANG } from "@/i18n";

const t = getTranslations(DEFAULT_LANG);
const baseUrl = import.meta.env.BASE_URL.replace(/\/?$/, "/");

const posts = (await getCollection("posts", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime(),
);

const categoryOrder = ["travel", "ai-insights", "thoughts"] as const;
const publishedCategories = new Set(posts.map((post) => post.data.category));
const categories = ["all", ...categoryOrder.filter((cat) => publishedCategories.has(cat))] as const;

const seriesDefinitions = [
  {
    slug: "humanities-ai-expert",
    roleZh: "Pillar",
    roleEn: "Pillar",
    noteZh: "先從文組人在企業 AI 導入裡的位置讀起。",
    noteEn: "Start with the humanities-led AI adoption frame.",
  },
  {
    slug: "ai-anxiety-survival-guide",
    roleZh: "Cluster A2",
    roleEn: "Cluster A2",
    noteZh: "接著回到個人焦慮：哪些價值值得留下。",
    noteEn: "Then move into individual AI anxiety and the 8% frame.",
  },
  {
    slug: "why-95-percent-ai-adoption-fails",
    roleZh: "Cluster A1",
    roleEn: "Cluster A1",
    noteZh: "再看企業現場：為什麼 pilot 常常沒有進到日常流程。",
    noteEn: "Then look at why enterprise AI pilots fail to become daily work.",
  },
  {
    slug: "zero-to-ai-native",
    roleZh: "Cluster B1",
    roleEn: "Cluster B1",
    noteZh: "最後走到 AI-Native：公司如何重新長成讓 agent 能工作的樣子。",
    noteEn: "End with the AI-native operating model.",
  },
] as const;

const postBySlug = new Map(posts.map((post) => [post.id.replace(/\.mdx?$/, ""), post]));
const aiSeries = seriesDefinitions
  .map((item) => ({ ...item, post: postBySlug.get(item.slug) }))
  .filter((item): item is typeof item & { post: NonNullable<typeof item.post> } => Boolean(item.post));
---

<BaseLayout
  title={t("blog.headline")}
  description={t("blog.description")}
>
  <Header />
  <main class="pt-32 pb-20 px-6">
    <div class="container max-w-5xl mx-auto">
      <div class="space-y-8 animate-fade-up">
        <div class="max-w-2xl">
          <p class="text-muted-foreground uppercase tracking-widest text-xs font-medium mb-4">
            <T k="blog.eyebrow" />
          </p>
          <h1 class="font-display text-4xl md:text-5xl font-medium leading-tight">
            <T k="blog.headline" />
          </h1>
          <p class="text-muted-foreground mt-4 text-lg"><T k="blog.description" /></p>
        </div>

        <!-- Search (Pagefind UI mounts here) -->
        <div class="max-w-md">
          <div id="search"></div>
        </div>

        <!-- Category filter (client-side, progressive enhancement) -->
        <div class="flex flex-wrap gap-2" data-category-filter>
          {
            categories.map((cat) => (
              <button
                type="button"
                data-cat={cat}
                class:list={[
                  "px-4 py-1.5 rounded-full text-sm border transition-colors",
                  cat === "all"
                    ? "bg-primary text-primary-foreground border-primary"
                    : "border-border hover:bg-secondary",
                ]}
              >
                <T k={`category.${cat}` as const} />
              </button>
            ))
          }
        </div>

        {
          aiSeries.length > 0 && (
            <section class="border-y border-border py-8 space-y-5" aria-labelledby="ai-series-heading">
              <div class="max-w-2xl space-y-2">
                <p class="text-muted-foreground uppercase tracking-widest text-xs font-medium">
                  <span data-l="zh">Start here</span>
                  <span data-l="en">Start here</span>
                </p>
                <h2 id="ai-series-heading" class="font-display text-2xl md:text-3xl font-medium">
                  <span data-l="zh">AI 導入系列：從焦慮、翻譯，到公司真的長出 AI 同事</span>
                  <span data-l="en">AI adoption series: from anxiety and translation to AI coworkers</span>
                </h2>
              </div>
              <div class="grid md:grid-cols-2 gap-4">
                {aiSeries.map((item) => {
                  const slug = item.post.id.replace(/\.mdx?$/, "");
                  return (
                    <a
                      href={`${baseUrl}blog/${slug}/`}
                      class="group block rounded-lg border border-border/60 bg-card p-5 transition-all duration-300 hover:-translate-y-0.5 hover:border-primary/40"
                    >
                      <div class="flex items-center gap-3 text-xs text-muted-foreground mb-3">
                        <span class="px-2.5 py-1 bg-secondary rounded-full text-secondary-foreground font-medium">
                          <span data-l="zh">{item.roleZh}</span>
                          <span data-l="en">{item.roleEn}</span>
                        </span>
                        <span>{item.post.data.readTime}</span>
                      </div>
                      <h3 class="font-display text-lg font-medium leading-snug group-hover:text-primary transition-colors">
                        {item.post.data.title}
                      </h3>
                      <p class="mt-3 text-sm text-muted-foreground leading-relaxed">
                        <span data-l="zh">{item.noteZh}</span>
                        <span data-l="en">{item.noteEn}</span>
                      </p>
                    </a>
                  );
                })}
              </div>
            </section>
          )
        }

        <div id="posts-grid" class="grid md:grid-cols-2 gap-6 pt-4">
          {posts.map((post, i) => (
            <div data-post data-cat={post.data.category}>
              <BlogCard post={post} index={i} />
            </div>
          ))}
        </div>

        <p
          id="no-results"
          class="hidden text-center py-20 text-muted-foreground"
        >
          <T k="blog.empty" />
        </p>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>

<!-- Pagefind UI -->
<link
  rel="stylesheet"
  href={`${baseUrl}pagefind/pagefind-ui.css`}
/>
<script src={`${baseUrl}pagefind/pagefind-ui.js`} is:inline></script>
<script is:inline define:vars={{ baseUrl }}>
  document.addEventListener("DOMContentLoaded", () => {
    if (window.PagefindUI) {
      const lang = document.documentElement.getAttribute("data-lang") || "zh";
      const isEn = lang === "en";
      new window.PagefindUI({
        element: "#search",
        showSubResults: true,
        showImages: false,
        bundlePath: `${baseUrl}pagefind/`,
        translations: isEn
          ? undefined
          : {
              placeholder: "搜尋文章...",
              clear_search: "清除",
              load_more: "顯示更多",
              search_label: "搜尋",
              filters_label: "篩選",
              zero_results: "找不到 [SEARCH_TERM] 相關的文章",
              many_results: "找到 [COUNT] 篇與 [SEARCH_TERM] 相關的文章",
              one_result: "找到 [COUNT] 篇與 [SEARCH_TERM] 相關的文章",
              alt_search: "找不到 [SEARCH_TERM] 相關的文章。改顯示 [DIFFERENT_TERM] 的搜尋結果",
              search_suggestion: "找不到 [SEARCH_TERM] 相關的文章。試試這些關鍵字：",
              searching: "搜尋中：[SEARCH_TERM]...",
            },
      });
    }
  });

  // Category filter (vanilla JS)
  document.addEventListener("DOMContentLoaded", () => {
    const filterContainer = document.querySelector("[data-category-filter]");
    if (!filterContainer) return;
    const buttons = filterContainer.querySelectorAll("button[data-cat]");
    const posts = document.querySelectorAll("#posts-grid [data-post]");
    const noResults = document.querySelector("#no-results");

    buttons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const target = btn.dataset.cat;
        buttons.forEach((b) => {
          const isActive = b === btn;
          b.classList.toggle("bg-primary", isActive);
          b.classList.toggle("text-primary-foreground", isActive);
          b.classList.toggle("border-primary", isActive);
          b.classList.toggle("border-border", !isActive);
          b.classList.toggle("hover:bg-secondary", !isActive);
        });
        let visible = 0;
        posts.forEach((p) => {
          const cat = p.dataset.cat;
          const show = target === "all" || cat === target;
          p.style.display = show ? "" : "none";
          if (show) visible++;
        });
        if (noResults) noResults.classList.toggle("hidden", visible !== 0);
      });
    });
  });
</script>
