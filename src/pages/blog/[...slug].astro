---
import { getCollection, render } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Comments from "@/components/Comments.astro";
import CaptureEye from "@/components/CaptureEye.astro";
import T from "@/components/T.astro";
import ShareButtons from "@/components/ShareButtons.astro";
import Reactions from "@/components/Reactions";
import { getTranslations, DEFAULT_LANG, type TranslationKey } from "@/i18n";

export async function getStaticPaths() {
  const posts = await getCollection("posts", ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id.replace(/\.mdx?$/, "") },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const t = getTranslations(DEFAULT_LANG);
const baseUrl = import.meta.env.BASE_URL.replace(/\/?$/, "/");
const currentSlug = post.id.replace(/\.mdx?$/, "");

const seriesDefinitions = [
  {
    slug: "humanities-ai-expert",
    roleZh: "Pillar",
    roleEn: "Pillar",
    noteZh: "文組人在企業 AI 導入裡的位置。",
    noteEn: "Humanities-led AI adoption.",
  },
  {
    slug: "ai-anxiety-survival-guide",
    roleZh: "Cluster A2",
    roleEn: "Cluster A2",
    noteZh: "AI 焦慮與 8% / 92% 框架。",
    noteEn: "AI anxiety and the 8% / 92% frame.",
  },
  {
    slug: "why-95-percent-ai-adoption-fails",
    roleZh: "Cluster A1",
    roleEn: "Cluster A1",
    noteZh: "企業 AI pilot 為什麼沒有進入日常流程。",
    noteEn: "Why AI pilots fail to become daily work.",
  },
  {
    slug: "zero-to-ai-native",
    roleZh: "Cluster B1",
    roleEn: "Cluster B1",
    noteZh: "公司如何重新長成 AI-Native。",
    noteEn: "How a company becomes AI-native.",
  },
] as const;

const allPublishedPosts = await getCollection("posts", ({ data }) => !data.draft);
const postBySlug = new Map(allPublishedPosts.map((entry) => [entry.id.replace(/\.mdx?$/, ""), entry]));
const aiSeries = seriesDefinitions
  .map((item) => ({ ...item, post: postBySlug.get(item.slug) }))
  .filter((item) => item.post);
const currentSeriesIndex = aiSeries.findIndex((item) => item.slug === currentSlug);
const currentSeries = currentSeriesIndex >= 0 ? aiSeries[currentSeriesIndex] : null;
const previousSeries = currentSeriesIndex > 0 ? aiSeries[currentSeriesIndex - 1] : null;
const nextSeries =
  currentSeriesIndex >= 0 && currentSeriesIndex < aiSeries.length - 1
    ? aiSeries[currentSeriesIndex + 1]
    : null;

const formatDate = (d: Date) =>
  d.toLocaleDateString("zh-TW", { year: "numeric", month: "long", day: "numeric" });

const categoryKey = (`category.${post.data.category}` as unknown) as TranslationKey;
const contextualCta =
  post.data.category === "ai-insights"
    ? {
        eyebrowZh: "Next",
        eyebrowEn: "Next",
        titleZh: "如果你想把這篇帶回團隊討論",
        titleEn: "If you want to bring this essay back to your team",
        descriptionZh:
          "這組 AI 文章不是工具清單，比較像幾個企業現場留下來的問題。下一步可以先看完整方法論，或直接討論適合團隊的演講 / workshop。",
        descriptionEn:
          "These AI essays are not tool lists. They are field notes from enterprise adoption work. Continue with the methodology, or discuss a talk / workshop for your team.",
        primaryHref: `${baseUrl}ai-coworker-methodology`,
        primaryZh: "看 AI 同事方法論",
        primaryEn: "Read the AI coworker methodology",
        secondaryHref: `${baseUrl}speaker`,
        secondaryZh: "邀請演講或工作坊",
        secondaryEn: "Invite a talk or workshop",
        marker: "blog-context-ai",
      }
    : post.data.category === "travel"
      ? {
          eyebrowZh: "Next",
          eyebrowEn: "Next",
          titleZh: "如果你是從旅行文字認識我",
          titleEn: "If you found me through the travel notes",
          descriptionZh:
            "旅行對我來說一直不是攻略，比較像練習觀察陌生系統。你可以接著看 About 裡的那條主線，或回到 Blog 繼續讀其他城市。",
          descriptionEn:
            "Travel, for me, is less itinerary and more practice in noticing unfamiliar systems. Continue with About, or return to the Blog for more city notes.",
          primaryHref: `${baseUrl}about`,
          primaryZh: "了解 Sofia 的主線",
          primaryEn: "Read Sofia's through-line",
          secondaryHref: `${baseUrl}blog`,
          secondaryZh: "回到所有文章",
          secondaryEn: "Back to all essays",
          marker: "blog-context-travel",
        }
      : null;
---

<BaseLayout
  title={post.data.title}
  description={post.data.excerpt}
  image={post.data.coverImage}
  type="article"
  article={{
    publishedTime: post.data.publishedAt.toISOString(),
    modifiedTime: post.data.updatedAt?.toISOString(),
    author: "Sofia Yan",
    tags: post.data.tags,
  }}
>
  <Header />
  <main class="pt-32 pb-20 px-6">
    <article class="container max-w-3xl mx-auto" data-pagefind-body>
      <a
        href={`${baseUrl}blog`}
        class="inline-flex items-center gap-2 text-sm text-muted-foreground hover:text-foreground transition-colors mb-8"
      >
        <span aria-hidden="true">←</span> <T k="blog.back" />
      </a>

      <header class="space-y-4 mb-8">
        <div class="flex items-center gap-4 text-sm flex-wrap">
          <span class="px-3 py-1 bg-secondary rounded-full text-secondary-foreground font-medium">
            <T k={categoryKey} />
          </span>
          <span class="text-muted-foreground">{formatDate(post.data.publishedAt)}</span>
          {post.data.readTime && (
            <span class="text-muted-foreground">· {post.data.readTime}</span>
          )}
        </div>

        <h1 class="font-display text-2xl md:text-3xl font-medium leading-tight">
          {post.data.title}
        </h1>

        {
          post.data.excerpt && (
            <p class="text-lg text-muted-foreground">{post.data.excerpt}</p>
          )
        }
      </header>

      {
        post.data.coverImage && (
          <div class="aspect-[16/9] rounded-xl overflow-hidden mb-12">
            {post.data.coverNid ? (
              <CaptureEye
                nid={post.data.coverNid}
                src={post.data.coverImage}
                alt={post.data.title}
                class="h-full"
                mediaClass="block aspect-[16/9] overflow-hidden"
                imgClass="w-full h-full object-cover"
                imgStyle="width: 100%; height: 100%; object-fit: cover;"
              />
            ) : (
              <img
                src={post.data.coverImage}
                alt={post.data.title}
                class="w-full h-full object-cover"
              />
            )}
          </div>
        )
      }

      <div
        class="prose prose-neutral dark:prose-invert max-w-none prose-img:rounded-lg prose-headings:font-display"
      >
        <Content />
      </div>

      {
        post.data.tags && post.data.tags.length > 0 && (
          <footer class="flex flex-wrap gap-2 mt-12 pt-8 border-t border-border">
            {post.data.tags.map((tag) => (
              <span class="px-3 py-1 bg-secondary rounded-full text-sm text-secondary-foreground">
                #{tag}
              </span>
            ))}
          </footer>
        )
      }

      {
        currentSeries && (
          <section class="mt-12 border-y border-border py-8 space-y-5" data-pagefind-ignore>
            <div class="space-y-2">
              <p class="text-muted-foreground uppercase tracking-widest text-xs font-medium">
                <span data-l="zh">AI adoption series</span>
                <span data-l="en">AI adoption series</span>
              </p>
              <h2 class="font-display text-xl font-medium">
                <span data-l="zh">這篇在系列裡的位置</span>
                <span data-l="en">Where this essay sits in the series</span>
              </h2>
              <p class="text-sm text-muted-foreground leading-relaxed">
                <span data-l="zh">這組文章從個人焦慮、文組翻譯能力，一路走到企業 AI 導入與 AI-Native 組織設計。</span>
                <span data-l="en">This series moves from individual anxiety and humanities translation into enterprise AI adoption and AI-native operating design.</span>
              </p>
            </div>

            <div class="grid md:grid-cols-2 gap-4">
              {previousSeries && (
                <a
                  href={`${baseUrl}blog/${previousSeries.slug}/`}
                  class="group rounded-lg border border-border/60 bg-card p-5 transition-all duration-300 hover:border-primary/40"
                >
                  <p class="text-xs text-muted-foreground mb-2">
                    <span data-l="zh">上一篇</span>
                    <span data-l="en">Previous</span>
                    <span> · </span>
                    <span data-l="zh">{previousSeries.roleZh}</span>
                    <span data-l="en">{previousSeries.roleEn}</span>
                  </p>
                  <h3 class="font-display text-lg font-medium leading-snug group-hover:text-primary transition-colors">
                    {previousSeries.post?.data.title}
                  </h3>
                  <p class="mt-3 text-sm text-muted-foreground">
                    <span data-l="zh">{previousSeries.noteZh}</span>
                    <span data-l="en">{previousSeries.noteEn}</span>
                  </p>
                </a>
              )}

              {nextSeries && (
                <a
                  href={`${baseUrl}blog/${nextSeries.slug}/`}
                  class="group rounded-lg border border-border/60 bg-card p-5 transition-all duration-300 hover:border-primary/40"
                >
                  <p class="text-xs text-muted-foreground mb-2">
                    <span data-l="zh">下一篇</span>
                    <span data-l="en">Next</span>
                    <span> · </span>
                    <span data-l="zh">{nextSeries.roleZh}</span>
                    <span data-l="en">{nextSeries.roleEn}</span>
                  </p>
                  <h3 class="font-display text-lg font-medium leading-snug group-hover:text-primary transition-colors">
                    {nextSeries.post?.data.title}
                  </h3>
                  <p class="mt-3 text-sm text-muted-foreground">
                    <span data-l="zh">{nextSeries.noteZh}</span>
                    <span data-l="en">{nextSeries.noteEn}</span>
                  </p>
                </a>
              )}
            </div>
          </section>
        )
      }

      {
        contextualCta && (
          <section
            class="mt-12 border-y border-border py-8 space-y-5"
            data-pagefind-ignore
            data-contextual-cta={contextualCta.marker}
          >
            <div class="space-y-2">
              <p class="text-muted-foreground uppercase tracking-widest text-xs font-medium">
                <span data-l="zh">{contextualCta.eyebrowZh}</span>
                <span data-l="en">{contextualCta.eyebrowEn}</span>
              </p>
              <h2 class="font-display text-xl font-medium">
                <span data-l="zh">{contextualCta.titleZh}</span>
                <span data-l="en">{contextualCta.titleEn}</span>
              </h2>
              <p class="text-sm text-muted-foreground leading-relaxed">
                <span data-l="zh">{contextualCta.descriptionZh}</span>
                <span data-l="en">{contextualCta.descriptionEn}</span>
              </p>
            </div>

            <div class="flex flex-wrap gap-4">
              <a
                href={contextualCta.primaryHref}
                class="inline-flex items-center gap-1 px-5 py-3 rounded-md bg-primary text-primary-foreground hover:opacity-90 transition-opacity font-medium"
                data-cta-role={`${contextualCta.marker}-primary`}
              >
                <span data-l="zh">{contextualCta.primaryZh}</span>
                <span data-l="en">{contextualCta.primaryEn}</span>
                <span aria-hidden="true">→</span>
              </a>
              <a
                href={contextualCta.secondaryHref}
                class="inline-flex items-center gap-1 px-5 py-3 rounded-md border border-border hover:bg-secondary transition-colors font-medium"
                data-cta-role={`${contextualCta.marker}-secondary`}
              >
                <span data-l="zh">{contextualCta.secondaryZh}</span>
                <span data-l="en">{contextualCta.secondaryEn}</span>
              </a>
            </div>
          </section>
        )
      }

      <div class="my-12 py-8 border-t border-b border-border grid grid-cols-1 md:grid-cols-2 gap-8" data-pagefind-ignore>
        <Reactions slug={currentSlug} client:only="react" />
        <div class="md:border-l md:border-border md:pl-8">
          <ShareButtons title={post.data.title} slug={post.id.replace(/\.mdx?$/, "")} />
        </div>
      </div>

      <Comments />
    </article>
  </main>
  <Footer />
</BaseLayout>
