---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import T from "@/components/T.astro";
import { getTranslations, DEFAULT_LANG } from "@/i18n";

const t = getTranslations(DEFAULT_LANG);
const baseUrl = import.meta.env.BASE_URL.replace(/\/?$/, "/");
---

<BaseLayout title={t("notfound.title")}>
  <Header />
  <main class="min-h-[60vh] flex items-center justify-center pt-32 pb-20 px-6">
    <div class="text-center space-y-6 animate-fade-up">
      <p class="font-display text-6xl md:text-7xl font-medium">404</p>
      <h1 class="font-display text-2xl md:text-3xl font-medium"><T k="notfound.title" /></h1>
      <p class="text-muted-foreground max-w-md mx-auto"><T k="notfound.description" /></p>
      <a
        href={baseUrl}
        class="inline-flex items-center gap-1 px-6 py-3 rounded-md bg-primary text-primary-foreground hover:opacity-90 transition-opacity font-medium"
      >
        <T k="notfound.home" />
      </a>
    </div>
  </main>
  <Footer />
</BaseLayout>
