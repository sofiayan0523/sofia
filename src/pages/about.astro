---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import CaptureEye from "@/components/CaptureEye.astro";
import T from "@/components/T.astro";

const baseUrl = import.meta.env.BASE_URL.replace(/\/?$/, "/");

const playgroundItems = [
  {
    emoji: "",
    titleZh: "Cat Reviews",
    titleEn: "Cat Reviews",
    descZh: "從鮪魚到 Twitter 討論串——來自這對貓咪的聲音。",
    descEn: "From tuna to Twitter threads — hear it from the duo.",
    link: "https://x.com/sofia_numbers",
  },
  {
    emoji: "",
    titleZh: "Book Stack",
    titleEn: "Book Stack",
    descZh: "從 AI 倫理到 zine 設計",
    descEn: "From AI ethics to zine design",
    link: "https://wecollect.fun/home/pP5lSFvUzlHHo1oBkbF9",
  },
  {
    emoji: "",
    titleZh: "Climbing Log",
    titleEn: "Climbing Log",
    descZh: "台北岩館 + 我最新的路線",
    descEn: "Taipei gyms + my latest sends",
    link: "https://www.instagram.com/shiji_zapie/reels/",
  },
  {
    emoji: "",
    titleZh: "City List",
    titleEn: "City List",
    descZh: "我獨自探索過的 70+ 個城市——還在增加中",
    descEn: "70+ cities I've solo-explored — and counting",
    link: "https://www.tripadvisor.com.tw/TravelMap-a_uid.62D80D5A0D26371C51F8738A6E080B84",
  },
];

const throughLineItems = [
  {
    labelZh: "教育與語言",
    labelEn: "Education & language",
    titleZh: "我先學會的不是賣技術，而是看人怎麼理解。",
    titleEn: "Before selling technology, I learned to watch how people understand.",
    descZh:
      "政大華語文教學碩士、臺北教育大學教育學士的背景，讓我很早就習慣把複雜的系統拆成人能進入的節奏。",
    descEn:
      "With an MA in Teaching Chinese as a Second Language from NCCU and a BA in Education from NTUE, I learned early to turn complex systems into rhythms people can enter.",
  },
  {
    labelZh: "新創現場",
    labelEn: "Startup field work",
    titleZh: "後來我把這種翻譯能力，帶進 AI、新創與內容信任。",
    titleEn: "Later, I carried that translation work into AI, startups, and content trust.",
    descZh:
      "從 AI / deep learning 新創、IP 估價，到 Numbers Protocol 的成長與國際合作，我看見同一個問題反覆出現：技術要被採用，得先被真正理解。",
    descEn:
      "Across AI and deep learning startups, IP valuation, and global growth at Numbers Protocol, the same question kept returning: technology needs to be understood before it can be adopted.",
  },
  {
    labelZh: "現在的題目",
    labelEn: "Current thesis",
    titleZh: "AI 不只是工具清單，而是組織要重新學會協作的對象。",
    titleEn: "AI is not just a tool list. It changes how organizations learn to work.",
    descZh:
      "我現在寫 AI coworker methodology，也談內容溯源與 C2PA，因為這些題目最後都回到信任：我們怎麼知道自己在和什麼合作、引用什麼、相信什麼。",
    descEn:
      "I now write about AI coworker methodology, content provenance, and C2PA because they return to trust: how we know what we are working with, citing, and believing.",
  },
];

const proofItems = [
  {
    titleZh: "完整經歷與公開紀錄",
    titleEn: "Full experience & public record",
    descZh:
      "我做過的專案、演講、媒體報導與 Podcast，都整理在這一頁。",
    descEn:
      "The projects, talks, media coverage, and podcasts I've been part of are all gathered in one place.",
    href: `${baseUrl}career`,
    linkZh: "看完整經歷",
    linkEn: "See full experience",
  },
  {
    titleZh: "邀我演講或工作坊",
    titleEn: "Invite me to speak",
    descZh:
      "想為團隊或活動找人談企業 AI 導入、AI 協作與內容溯源——這裡有主題與聯絡方式。",
    descEn:
      "Looking for someone to talk with your team or event about enterprise AI adoption, AI collaboration, and content provenance — topics and contact are here.",
    href: `${baseUrl}speaker`,
    linkZh: "看演講邀約",
    linkEn: "See speaking page",
  },
];
---

<BaseLayout
  title="關於 Sofia"
  description="Numbers Protocol 共同創辦人，熱愛旅行、攀岩與科技。探索 AI、區塊鏈與數位內容驗證的故事。"
>
  <Header />
  <main class="pt-32 pb-20 px-6">
    <div class="container max-w-3xl mx-auto">
      <div class="animate-fade-up space-y-8">
        <div>
          <p class="text-muted-foreground uppercase tracking-widest text-xs font-medium mb-4">
            <T k="about.eyebrow" />
          </p>
          <h1 class="font-display text-2xl md:text-3xl font-medium leading-tight">
            <T k="about.headline" />
          </h1>
        </div>

        <div class="w-64 md:w-80 rounded-xl overflow-hidden">
          <CaptureEye
            nid="bafybeigro6ao7gyxcjzfyvgicmmdl56iyuj2vbfdswbu4aicytv4efreo4"
            src={`${baseUrl}images/profile/sofia.png`}
            alt="Sofia Yan"
            imgClass="w-full h-auto aspect-square object-cover object-top"
          />
        </div>

        <div class="prose prose-neutral dark:prose-invert max-w-none space-y-6 text-foreground/80 leading-relaxed">
          <p class="text-lg"><T k="about.intro" /></p>
          <p><T k="about.background" /></p>
          <p><T k="about.hobbies" /></p>

          <h2 class="font-display text-xl font-medium text-foreground pt-8">
            <T k="about.currentlyTitle" />
          </h2>

          <ul class="space-y-2">
            <li><T k="about.current1" /></li>
            <li><T k="about.current2" /></li>
            <li><T k="about.current3" /></li>
            <li><T k="about.current4" /></li>
          </ul>
        </div>
      </div>

      <section class="mt-16 space-y-8 border-t border-border pt-12">
        <div class="space-y-3">
          <p class="text-muted-foreground uppercase tracking-widest text-xs font-medium">
            <span data-l="zh">Through-line</span><span data-l="en">Through-line</span>
          </p>
          <h2 class="font-display text-xl md:text-2xl font-medium">
            <span data-l="zh">我看 AI 的方式，從來不只來自 AI。</span>
            <span data-l="en">The way I see AI never came only from AI.</span>
          </h2>
        </div>

        <div class="space-y-5">
          {
            throughLineItems.map((item) => (
              <article class="border-l border-border pl-5 py-1">
                <p class="text-muted-foreground uppercase tracking-widest text-xs font-medium mb-2">
                  <span data-l="zh">{item.labelZh}</span><span data-l="en">{item.labelEn}</span>
                </p>
                <h3 class="font-display text-xl font-medium text-foreground mb-2">
                  <span data-l="zh">{item.titleZh}</span><span data-l="en">{item.titleEn}</span>
                </h3>
                <p class="text-foreground/75 leading-relaxed">
                  <span data-l="zh">{item.descZh}</span><span data-l="en">{item.descEn}</span>
                </p>
              </article>
            ))
          }
        </div>
      </section>

      <section class="mt-16 space-y-6 border-t border-border pt-12">
        <div class="space-y-3">
          <p class="text-muted-foreground uppercase tracking-widest text-xs font-medium">
            <span data-l="zh">Playground</span><span data-l="en">Playground</span>
          </p>
          <h2 class="font-display text-xl md:text-2xl font-medium">
            <T k="about.playgroundTitle" />
          </h2>
          <p class="text-muted-foreground max-w-2xl"><T k="about.playgroundDescription" /></p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {
            playgroundItems.map((item) => (
              <a
                href={item.link}
                target="_blank"
                rel="noopener noreferrer"
                class="group p-6 rounded-lg border border-border/60 hover:border-primary/40 transition-colors duration-300"
              >
                <h3 class="font-display text-lg font-medium mb-2 flex items-center gap-2 group-hover:text-primary transition-colors">
                  <span><span data-l="zh">{item.titleZh}</span><span data-l="en">{item.titleEn}</span></span>
                  <span class="text-muted-foreground text-sm" aria-hidden="true">↗</span>
                </h3>
                <p class="text-sm text-muted-foreground">
                  <span data-l="zh">{item.descZh}</span><span data-l="en">{item.descEn}</span>
                </p>
              </a>
            ))
          }
        </div>
      </section>

      <!-- Compact E-E-A-T receipts; dense chronology lives on Career and Speaker. -->
      <section class="mt-16 space-y-8 border-t border-border pt-12">
        <div class="space-y-3">
          <p class="text-muted-foreground uppercase tracking-widest text-xs font-medium">
            <span data-l="zh">延伸了解</span><span data-l="en">Go deeper</span>
          </p>
          <h2 class="font-display text-xl md:text-2xl font-medium">
            <span data-l="zh">想更了解我，或想找我合作？</span>
            <span data-l="en">Want to go deeper, or work together?</span>
          </h2>
        </div>

        <div class="grid md:grid-cols-2 gap-x-10">
          {
            proofItems.map((item) => (
              <article class="border-t border-border/60 py-6">
                <h3 class="font-display text-lg font-medium mb-2">
                  <span data-l="zh">{item.titleZh}</span><span data-l="en">{item.titleEn}</span>
                </h3>
                <p class="text-sm text-foreground/75 leading-relaxed mb-4">
                  <span data-l="zh">{item.descZh}</span><span data-l="en">{item.descEn}</span>
                </p>
                <a href={item.href} class="text-sm text-primary underline hover:no-underline">
                  <span data-l="zh">{item.linkZh}</span><span data-l="en">{item.linkEn}</span>
                </a>
              </article>
            ))
          }
        </div>

        <div class="space-y-4 text-sm text-foreground/75 leading-relaxed">
          <p>
            <span data-l="zh">
              Numbers Protocol 為 AI agentic economy 建構內容溯源基礎建設；團隊為 C2PA 會員，曾共同設計 ERC-7053 / ERC-7517，
              也出現在 SXSW 2023 Pitch、UNICRI、Google News Initiative 等公開場域。
            </span>
            <span data-l="en">
              Numbers Protocol builds content provenance infrastructure for the AI agentic economy; the team is a C2PA member,
              co-designed ERC-7053 / ERC-7517, and has appeared in public venues including SXSW 2023 Pitch, UNICRI, and Google News Initiative.
            </span>
          </p>

          <p class="text-xs text-muted-foreground border-t border-border pt-4">
            <span data-l="zh">已公開可查證來源：</span><span data-l="en">Publicly verifiable sources: </span>
            <a href="https://tw.linkedin.com/in/sofia-yan-b6318a31" class="underline hover:no-underline">LinkedIn</a> ·
            <a href="https://www.crunchbase.com/person/sofia-yan" class="underline hover:no-underline">Crunchbase</a> ·
            <a href="https://theorg.com/org/numbers-protocol/org-chart/sofia-yan" class="underline hover:no-underline">TheOrg</a> ·
            <a href="https://www.numbersprotocol.io" class="underline hover:no-underline">Numbers Protocol</a>
          </p>
        </div>
      </section>

      <section class="mt-16 border-t border-border pt-10 space-y-5">
        <div class="space-y-2">
          <p class="text-muted-foreground uppercase tracking-widest text-xs font-medium">
            <span data-l="zh">Next</span><span data-l="en">Next</span>
          </p>
          <h2 class="font-display text-xl md:text-2xl font-medium">
            <span data-l="zh">如果你想接著看我怎麼想 AI 與工作</span>
            <span data-l="en">If you want to keep following how I think about AI and work</span>
          </h2>
        </div>
        <div class="flex flex-wrap gap-4">
          <a
            href={`${baseUrl}blog`}
            class="inline-flex items-center gap-1 px-5 py-3 rounded-md bg-primary text-primary-foreground hover:opacity-90 transition-opacity font-medium"
          >
            <span data-l="zh">閱讀文章</span><span data-l="en">Read essays</span>
            <span aria-hidden="true">→</span>
          </a>
          <a
            href={`${baseUrl}speaker`}
            class="inline-flex items-center gap-1 px-5 py-3 rounded-md border border-border hover:bg-secondary transition-colors font-medium"
          >
            <span data-l="zh">邀請演講或工作坊</span><span data-l="en">Invite a talk or workshop</span>
          </a>
        </div>
      </section>
    </div>
  </main>
  <Footer />
</BaseLayout>
