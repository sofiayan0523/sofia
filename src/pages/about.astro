---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import CaptureEye from "@/components/CaptureEye.astro";
import T from "@/components/T.astro";

const baseUrl = import.meta.env.BASE_URL.replace(/\/?$/, "/");

const playgroundItems = [
  {
    emoji: "🐾",
    titleZh: "Cat Reviews",
    titleEn: "Cat Reviews",
    descZh: "從鮪魚到 Twitter 討論串——來自這對貓咪的聲音。",
    descEn: "From tuna to Twitter threads — hear it from the duo.",
    link: "https://x.com/sofia_numbers",
  },
  {
    emoji: "📚",
    titleZh: "Book Stack",
    titleEn: "Book Stack",
    descZh: "從 AI 倫理到 zine 設計",
    descEn: "From AI ethics to zine design",
    link: "https://wecollect.fun/home/pP5lSFvUzlHHo1oBkbF9",
  },
  {
    emoji: "🧗",
    titleZh: "Climbing Log",
    titleEn: "Climbing Log",
    descZh: "台北岩館 + 我最新的路線",
    descEn: "Taipei gyms + my latest sends",
    link: "https://www.instagram.com/shiji_zapie/reels/",
  },
  {
    emoji: "🌍",
    titleZh: "City List",
    titleEn: "City List",
    descZh: "我獨自探索過的 70+ 個城市——還在增加中",
    descEn: "70+ cities I've solo-explored — and counting",
    link: "https://www.tripadvisor.com.tw/TravelMap-a_uid.62D80D5A0D26371C51F8738A6E080B84",
  },
];
---

<BaseLayout
  title="關於 Sofia"
  description="Numbers Protocol 共同創辦人，熱愛旅行、攀岩與科技。探索 AI、區塊鏈與數位內容驗證的故事。"
>
  <Header />
  <main class="pt-32 pb-20 px-6">
    <div class="container max-w-3xl mx-auto">
      <div class="animate-fade-up space-y-8">
        <div>
          <p class="text-muted-foreground uppercase tracking-widest text-xs font-medium mb-4">
            <T k="about.eyebrow" />
          </p>
          <h1 class="font-display text-4xl md:text-5xl font-medium leading-tight">
            <T k="about.headline" />
          </h1>
        </div>

        <div class="w-64 md:w-80 rounded-xl overflow-hidden">
          <CaptureEye
            nid="bafybeigro6ao7gyxcjzfyvgicmmdl56iyuj2vbfdswbu4aicytv4efreo4"
            src={`${baseUrl}images/profile/sofia.png`}
            alt="Sofia Yan"
            imgClass="w-full h-auto aspect-square object-cover object-top"
          />
        </div>

        <div class="prose prose-neutral dark:prose-invert max-w-none space-y-6 text-foreground/80 leading-relaxed">
          <p class="text-lg"><T k="about.intro" /></p>
          <p><T k="about.background" /></p>
          <p><T k="about.hobbies" /></p>

          <h2 class="font-display text-2xl font-medium text-foreground pt-8">
            <T k="about.currentlyTitle" />
          </h2>

          <ul class="space-y-2">
            <li>🏠 <T k="about.current1" /></li>
            <li>🎤 <T k="about.current2" /></li>
            <li>✍️ <T k="about.current3" /></li>
            <li>🧗‍♀️ <T k="about.current4" /></li>
          </ul>

          <h2 class="font-display text-2xl font-medium text-foreground pt-8">
            <T k="about.playgroundTitle" />
          </h2>
          <p class="text-muted-foreground"><T k="about.playgroundDescription" /></p>
        </div>
      </div>

      <!-- Credentials & Speaking (E-E-A-T strengthening) -->
      <section class="mt-16 space-y-10 border-t border-border pt-12">
        <div class="space-y-3">
          <p class="text-muted-foreground uppercase tracking-widest text-xs font-medium">
            <span data-l="zh">學經歷與認證</span><span data-l="en">Credentials</span>
          </p>
          <h2 class="font-display text-2xl md:text-3xl font-medium">
            <span data-l="zh">為什麼是我</span><span data-l="en">Why me</span>
          </h2>
        </div>

        <div class="grid md:grid-cols-2 gap-8 text-foreground/80 leading-relaxed">
          <div class="space-y-3">
            <h3 class="font-display text-lg font-medium text-foreground">
              <span data-l="zh">學歷</span><span data-l="en">Education</span>
            </h3>
            <ul class="space-y-2 text-sm">
              <li>🎓 <strong>國立政治大學</strong>（NCCU）<span data-l="zh"> · 華語文教學碩士</span><span data-l="en"> · MA, Teaching Chinese as a Second Language</span></li>
              <li>🎓 <strong>國立臺北教育大學</strong>（NTUE）<span data-l="zh"> · 教育學士</span><span data-l="en"> · BA, Education</span></li>
              <li>📜 <span data-l="zh">對外華語教學能力證書</span><span data-l="en">Certified Teacher of Chinese as a Foreign Language</span></li>
              <li>📜 <span data-l="zh">國小教師證</span><span data-l="en">Elementary School Teaching License</span></li>
              <li>📜 <span data-l="zh">Anthropic "Building with the Claude API"（2026）</span><span data-l="en">Anthropic "Building with the Claude API" (2026)</span></li>
            </ul>
          </div>

          <div class="space-y-3">
            <h3 class="font-display text-lg font-medium text-foreground">
              <span data-l="zh">職涯</span><span data-l="en">Career</span>
            </h3>
            <ul class="space-y-2 text-sm">
              <li>🚀 <strong>Numbers Protocol</strong>
                <span data-l="zh"> · Co-Founder & CGO（2019–）</span>
                <span data-l="en"> · Co-Founder & Chief Growth Officer (2019–present)</span>
              </li>
              <li>📸 <strong>Capture</strong>
                <span data-l="zh"> · 行銷長（Numbers Protocol 旗下內容溯源產品線）</span>
                <span data-l="en"> · Head of Marketing (Numbers Protocol's content provenance product line)</span>
              </li>
              <li>🧠 <strong>WebBrain AI</strong>
                <span data-l="zh"> · 行銷長</span>
                <span data-l="en"> · Head of Marketing</span>
              </li>
              <li>🎬 <strong>科科 AI Shorts</strong>
                <span data-l="zh"> · YouTube 頻道負責人（AI 工具實測、Vibe Coding 入門）</span>
                <span data-l="en"> · YouTube channel lead (AI tools, vibe coding for non-engineers)</span>
              </li>
              <li>🤖 <strong>DT42</strong>
                <span data-l="zh"> · BD Director（AI / deep learning startup）</span>
                <span data-l="en"> · Director of BD (AI / deep learning)</span>
              </li>
              <li>⚖️ <strong>成大智權科技 Chengda IP Tech</strong>
                <span data-l="zh"> · IP 估價 BD Manager</span>
                <span data-l="en"> · BD Manager / IP valuation</span>
              </li>
              <li>📣
                <span data-l="zh">10+ 年 BD / sales / marketing 跨 AI 新創與 IP 估價</span>
                <span data-l="en">10+ years across BD / sales / marketing in AI startups and IP valuation</span>
              </li>
            </ul>
          </div>
        </div>

        <div class="space-y-3">
          <h3 class="font-display text-lg font-medium text-foreground">
            <span data-l="zh">演講足跡（節錄）</span><span data-l="en">Speaking history (selected)</span>
          </h3>
          <ul class="grid md:grid-cols-2 gap-x-8 gap-y-2 text-sm text-foreground/80">
            <li>🏆 SXSW 2023 Pitch <span data-l="zh">（Metaverse & Web3 冠軍，Numbers 團隊）</span><span data-l="en">(Metaverse & Web3 winner, team)</span></li>
            <li>🎙 Asia Pacific Journalism Forum 2025</li>
            <li>🌏 UNICRI <span data-l="zh">（聯合國跨區域犯罪暨司法研究所）</span><span data-l="en">(UN Interregional Crime & Justice Research Institute)</span></li>
            <li>📰 Google News Initiative <span data-l="zh">補助計畫獲獎人（2025）</span><span data-l="en">grant recipient (2025)</span></li>
            <li>📺 AAJA-Asia <span data-l="zh">假訊息議題座談</span><span data-l="en">misinformation panels</span></li>
            <li>🎓 NTU TEC Talk S2EP1 <span data-l="zh">（台大創創中心）</span><span data-l="en">(NTU Entrepreneurship Centre)</span></li>
            <li>🇹🇼 伙影通訊社 <span data-l="zh">共同合作（與余志偉）</span><span data-l="en">co-founder partnership (with photographer Yu Chih-wei)</span></li>
          </ul>
          <p class="text-sm text-muted-foreground pt-2">
            <span data-l="zh">→ 想邀請演講？</span><span data-l="en">→ Want to invite Sofia to speak?</span>
            <a href={`${baseUrl}speaker`} class="text-primary underline hover:no-underline ml-1">
              <span data-l="zh">看 Speaker page</span><span data-l="en">See speaker page</span>
            </a>
          </p>
        </div>

        <div class="space-y-3">
          <h3 class="font-display text-lg font-medium text-foreground">
            <span data-l="zh">Numbers Protocol 背景</span><span data-l="en">Numbers Protocol context</span>
          </h3>
          <p class="text-sm text-foreground/80 leading-relaxed">
            <span data-l="zh">
              Numbers Protocol（主張數據股份有限公司，2019 創立）為 AI agentic economy 建構內容溯源基礎建設。
              C2PA 會員、被 NIST AI Risk Management Framework 引用、共同設計 ERC-7053 與 ERC-7517 標準、
              67M+ 數位資產註冊量、與 Adobe / Microsoft / Nikon / Reuters 等合作。
              Tagline：「Human Truth, Machine Proof」。
            </span>
            <span data-l="en">
              Numbers Protocol (founded 2019) builds provenance infrastructure for the AI agentic economy.
              C2PA member; cited by NIST AI Risk Management Framework; co-designed ERC-7053 and ERC-7517 Ethereum standards;
              67M+ digital asset registrations; partners include Adobe, Microsoft, Nikon, Reuters.
              Tagline: "Human Truth, Machine Proof".
            </span>
          </p>
        </div>

        <div class="text-xs text-muted-foreground border-t border-border pt-6">
          <span data-l="zh">已公開可查證來源：</span><span data-l="en">Publicly verifiable sources: </span>
          <a href="https://tw.linkedin.com/in/sofia-yan-b6318a31" class="underline hover:no-underline">LinkedIn</a> ·
          <a href="https://www.crunchbase.com/person/sofia-yan" class="underline hover:no-underline">Crunchbase</a> ·
          <a href="https://theorg.com/org/numbers-protocol/org-chart/sofia-yan" class="underline hover:no-underline">TheOrg</a> ·
          <a href="https://www.numbersprotocol.io" class="underline hover:no-underline">Numbers Protocol</a>
        </div>
      </section>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 mt-8">
        {
          playgroundItems.map((item) => (
            <a
              href={item.link}
              target="_blank"
              rel="noopener noreferrer"
              class="group p-6 rounded-xl bg-card border border-border hover:border-primary/30 transition-all duration-300"
            >
              <div class="flex items-center justify-between mb-3">
                <span class="text-3xl">{item.emoji}</span>
                <span
                  class="text-muted-foreground opacity-0 group-hover:opacity-100 transition-opacity"
                  aria-hidden="true"
                >
                  ↗
                </span>
              </div>
              <h3 class="font-display text-lg font-medium mb-2 group-hover:text-primary transition-colors">
                <span data-l="zh">{item.titleZh}</span><span data-l="en">{item.titleEn}</span>
              </h3>
              <p class="text-sm text-muted-foreground">
                <span data-l="zh">{item.descZh}</span><span data-l="en">{item.descEn}</span>
              </p>
            </a>
          ))
        }
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>
