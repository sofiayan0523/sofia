---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import CaptureEye from "@/components/CaptureEye.astro";
import { getTranslations, DEFAULT_LANG } from "@/i18n";

const t = getTranslations(DEFAULT_LANG);
const baseUrl = import.meta.env.BASE_URL.replace(/\/?$/, "/");

const playgroundItems = [
  {
    emoji: "🐾",
    title: "Cat Reviews",
    description: "從鮪魚到 Twitter 討論串——來自這對貓咪的聲音。",
    link: "https://x.com/sofia_numbers",
  },
  {
    emoji: "🎵",
    title: "Coding Playlist",
    description: "我工作時聽的音樂",
    link: "https://open.spotify.com/playlist/37i9dQZF1DWVidGk00tysG?si=b6b00b9e03b24a59",
  },
  {
    emoji: "📚",
    title: "Book Stack",
    description: "從 AI 倫理到 zine 設計",
    link: "https://wecollect.fun/home/pP5lSFvUzlHHo1oBkbF9",
  },
  {
    emoji: "🧗",
    title: "Climbing Log",
    description: "台北岩館 + 我最新的路線",
    link: "https://www.instagram.com/shiji_zapie/reels/",
  },
  {
    emoji: "🌍",
    title: "City List",
    description: "我獨自探索過的 70+ 個城市——還在增加中",
    link: "https://www.tripadvisor.com.tw/TravelMap-a_uid.62D80D5A0D26371C51F8738A6E080B84",
  },
];
---

<BaseLayout
  title="關於 Sofia"
  description="Numbers Protocol 共同創辦人，熱愛旅行、攀岩與科技。探索 AI、區塊鏈與數位內容驗證的故事。"
>
  <Header />
  <main class="pt-32 pb-20 px-6">
    <div class="container max-w-3xl mx-auto">
      <div class="animate-fade-up space-y-8">
        <div>
          <p class="text-muted-foreground uppercase tracking-widest text-xs font-medium mb-4">
            {t("about.eyebrow")}
          </p>
          <h1 class="font-display text-4xl md:text-5xl font-medium leading-tight">
            {t("about.headline")}
          </h1>
        </div>

        <div class="w-64 md:w-80 rounded-xl overflow-hidden">
          <CaptureEye
            nid="bafybeigro6ao7gyxcjzfyvgicmmdl56iyuj2vbfdswbu4aicytv4efreo4"
            src={`${baseUrl}images/profile/sofia.png`}
            alt="Sofia Yan"
            imgClass="w-full h-auto aspect-square object-cover object-top"
          />
        </div>

        <div class="prose prose-neutral dark:prose-invert max-w-none space-y-6 text-foreground/80 leading-relaxed">
          <p class="text-lg">{t("about.intro")}</p>
          <p>{t("about.background")}</p>
          <p>{t("about.hobbies")}</p>

          <h2 class="font-display text-2xl font-medium text-foreground pt-8">
            {t("about.currentlyTitle")}
          </h2>

          <ul class="space-y-2">
            <li>🏠 {t("about.current1")}</li>
            <li>🎤 {t("about.current2")}</li>
            <li>✍️ {t("about.current3")}</li>
            <li>🧗‍♀️ {t("about.current4")}</li>
          </ul>

          <h2 class="font-display text-2xl font-medium text-foreground pt-8">
            {t("about.playgroundTitle")}
          </h2>
          <p class="text-muted-foreground">{t("about.playgroundDescription")}</p>
        </div>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 mt-8">
        {
          playgroundItems.map((item) => (
            <a
              href={item.link}
              target="_blank"
              rel="noopener noreferrer"
              class="group p-6 rounded-xl bg-card border border-border hover:border-primary/30 transition-all duration-300"
            >
              <div class="flex items-center justify-between mb-3">
                <span class="text-3xl">{item.emoji}</span>
                <span
                  class="text-muted-foreground opacity-0 group-hover:opacity-100 transition-opacity"
                  aria-hidden="true"
                >
                  ↗
                </span>
              </div>
              <h3 class="font-display text-lg font-medium mb-2 group-hover:text-primary transition-colors">
                {item.title}
              </h3>
              <p class="text-sm text-muted-foreground">{item.description}</p>
            </a>
          ))
        }
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>
