---
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("posts", ({ data }) => !data.draft);
  return posts.map((post) => {
    const slug = post.id.replace(/\.mdx?$/, "");
    return {
      params: { slug },
      props: {
        title: post.data.title,
        targetPath: `/blog/${slug}/`,
      },
    };
  });
}

const { title, targetPath } = Astro.props;
const siteOrigin = Astro.site?.toString().replace(/\/$/, "") ?? "https://sofiayan.cc";
const targetUrl = `${siteOrigin}${targetPath}`;
---

<!doctype html>
<html lang="zh-TW">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} moved to /blog/ | Sofia Yan</title>
    <meta name="robots" content="noindex, follow" />
    <link rel="canonical" href={targetUrl} />
    <meta http-equiv="refresh" content={`0; url=${targetPath}`} />
    <script is:inline define:vars={{ targetPath }}>
      window.location.replace(targetPath);
    </script>
  </head>
  <body>
    <main>
      <h1>文章已移至新網址</h1>
      <p>
        <a href={targetPath}>前往新版文章頁：{title}</a>
      </p>
    </main>
  </body>
</html>
