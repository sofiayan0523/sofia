---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import BlogCard from "@/components/BlogCard.astro";
import CaptureEye from "@/components/CaptureEye.astro";
import T from "@/components/T.astro";
import type { TranslationKey } from "@/i18n";

const baseUrl = import.meta.env.BASE_URL.replace(/\/?$/, "/");

const allPosts = (await getCollection("posts", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime(),
);
const featured = allPosts.slice(0, 6);

// Guided AI adoption reading path — a "start here" entry for first-time visitors.
const seriesDefinitions = [
  {
    slug: "humanities-ai-expert",
    noteZh: "先從文組人在企業 AI 導入裡的位置讀起。",
    noteEn: "Start with the humanities-led AI adoption frame.",
  },
  {
    slug: "ai-anxiety-survival-guide",
    noteZh: "接著回到個人焦慮：哪些價值值得留下。",
    noteEn: "Then move into individual AI anxiety and what's worth keeping.",
  },
  {
    slug: "why-95-percent-ai-adoption-fails",
    noteZh: "再看企業現場：為什麼 pilot 常常沒有進到日常流程。",
    noteEn: "Then look at why enterprise AI pilots fail to become daily work.",
  },
  {
    slug: "zero-to-ai-native",
    noteZh: "最後走到 AI-Native：公司如何重新長成讓 agent 能工作的樣子。",
    noteEn: "End with the AI-native operating model.",
  },
] as const;

const postBySlug = new Map(allPosts.map((post) => [post.id.replace(/\.mdx?$/, ""), post]));
const aiSeries = seriesDefinitions
  .map((item) => ({ ...item, post: postBySlug.get(item.slug) }))
  .filter((item): item is typeof item & { post: NonNullable<typeof item.post> } => Boolean(item.post));

const stats: { value: string; labelKey: TranslationKey }[] = [
  { value: "50+", labelKey: "home.stat.cities" },
  { value: "10+", labelKey: "home.stat.tech" },
  { value: "20+", labelKey: "home.stat.speaking" },
  { value: "∞", labelKey: "home.stat.curiosity" },
];
---

<BaseLayout>
  <Header />
  <main>
    <!-- Hero -->
    <section class="pt-32 pb-20 px-6">
      <div class="container max-w-5xl mx-auto">
        <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-12">
          <div class="max-w-2xl space-y-6 animate-fade-up">
            <p class="text-muted-foreground uppercase tracking-widest text-xs font-medium">
              <T k="home.eyebrow" />
            </p>
            <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-medium leading-[1.1] tracking-tight">
              <T k="home.greeting" />
            </h1>
            <p class="text-lg md:text-xl text-muted-foreground leading-relaxed max-w-xl whitespace-pre-line">
              <T k="home.description" />
            </p>
            <div class="flex flex-wrap gap-2 text-sm text-foreground/80">
              <span class="px-3 py-1 rounded-full bg-secondary">
                <T k="home.focus.ai" />
              </span>
              <span class="px-3 py-1 rounded-full bg-secondary">
                <T k="home.focus.provenance" />
              </span>
              <span class="px-3 py-1 rounded-full bg-secondary">
                <T k="home.focus.coworker" />
              </span>
            </div>
            <div class="flex flex-wrap gap-4 pt-4">
              <a
                href={`${baseUrl}speaker`}
                class="inline-flex items-center gap-1 px-6 py-3 rounded-md bg-primary text-primary-foreground hover:opacity-90 transition-opacity font-medium"
              >
                <T k="home.speakerBtn" /> <span aria-hidden="true">→</span>
              </a>
              <a
                href={`${baseUrl}blog`}
                class="inline-flex items-center gap-1 px-6 py-3 rounded-md border border-border hover:bg-secondary transition-colors font-medium"
              >
                <T k="home.blogBtn" />
              </a>
              <a
                href={`${baseUrl}about`}
                class="inline-flex items-center gap-1 px-6 py-3 rounded-md border border-transparent hover:bg-secondary transition-colors font-medium text-muted-foreground hover:text-foreground"
              >
                <T k="home.aboutBtn" />
              </a>
            </div>
          </div>

          <div
            class="w-48 md:w-64 rounded-xl overflow-hidden flex-shrink-0 animate-fade-up"
            style="animation-delay: 200ms"
          >
            <CaptureEye
              nid="bafybeigro6ao7gyxcjzfyvgicmmdl56iyuj2vbfdswbu4aicytv4efreo4"
              src={`${baseUrl}images/profile/sofia.png`}
              alt="Sofia Yan"
              imgClass="w-full h-auto aspect-square object-cover object-top rounded-xl"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- Stats -->
    <section class="py-16 px-6 border-y border-border/50">
      <div class="container max-w-5xl mx-auto">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
          {
            stats.map((stat, i) => (
              <div
                class="animate-fade-up"
                style={`animation-delay: ${i * 100 + 200}ms`}
              >
                <p class="font-display text-2xl md:text-3xl font-medium">{stat.value}</p>
                <p class="text-muted-foreground text-sm mt-1">
                  <T k={stat.labelKey} />
                </p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Start here: guided AI adoption reading path -->
    {
      aiSeries.length > 0 && (
        <section class="py-20 px-6 border-b border-border/50" aria-labelledby="start-here-heading">
          <div class="container max-w-5xl mx-auto space-y-8">
            <div class="max-w-2xl space-y-2">
              <p class="text-muted-foreground uppercase tracking-widest text-xs font-medium">
                <span data-l="zh">第一次來？從這裡開始</span>
                <span data-l="en">First time here? Start here</span>
              </p>
              <h2 id="start-here-heading" class="font-display text-2xl md:text-3xl font-medium">
                <span data-l="zh">AI 導入系列：從焦慮、翻譯，到公司真的長出 AI 同事</span>
                <span data-l="en">AI adoption series: from anxiety and translation to AI coworkers</span>
              </h2>
              <p class="text-muted-foreground">
                <span data-l="zh">四篇一條線，建議照順序讀。</span>
                <span data-l="en">Four essays, one throughline — best read in order.</span>
              </p>
            </div>
            <div class="grid md:grid-cols-2 gap-4">
              {aiSeries.map((item, i) => {
                const slug = item.post.id.replace(/\.mdx?$/, "");
                return (
                  <a
                    href={`${baseUrl}blog/${slug}/`}
                    class="group block rounded-lg border border-border/60 bg-card p-5 transition-all duration-300 hover:-translate-y-0.5 hover:border-primary/40"
                  >
                    <div class="flex items-center gap-3 text-xs text-muted-foreground mb-3">
                      <span class="flex h-6 w-6 items-center justify-center rounded-full bg-secondary text-secondary-foreground font-medium">
                        {i + 1}
                      </span>
                      <span>{item.post.data.readTime}</span>
                    </div>
                    <h3 class="font-display text-lg font-medium leading-snug group-hover:text-primary transition-colors">
                      {item.post.data.title}
                    </h3>
                    <p class="mt-3 text-sm text-muted-foreground leading-relaxed">
                      <span data-l="zh">{item.noteZh}</span>
                      <span data-l="en">{item.noteEn}</span>
                    </p>
                  </a>
                );
              })}
            </div>
          </div>
        </section>
      )
    }

    <!-- Featured posts -->
    <section class="py-20 px-6">
      <div class="container max-w-5xl mx-auto">
        <div class="flex items-end justify-between mb-12">
          <div>
            <p class="text-muted-foreground uppercase tracking-widest text-xs font-medium mb-2">
              <T k="home.latestEyebrow" />
            </p>
            <h2 class="font-display text-2xl md:text-3xl font-medium">
              <T k="home.latestTitle" />
            </h2>
          </div>
          <a
            href={`${baseUrl}blog`}
            class="hidden md:inline-flex items-center gap-1 text-sm hover:text-muted-foreground transition-colors"
          >
            <T k="home.viewAll" /> <span aria-hidden="true">→</span>
          </a>
        </div>

        {
          featured.length > 0 ? (
            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
              {featured.map((post, i) => (
                <BlogCard post={post} index={i} />
              ))}
            </div>
          ) : (
            <p class="text-center py-12 text-muted-foreground">
              <T k="home.empty" />
            </p>
          )
        }

        <div class="mt-8 text-center md:hidden">
          <a
            href={`${baseUrl}blog`}
            class="inline-flex items-center gap-1 px-6 py-3 rounded-md border border-border hover:bg-secondary transition-colors font-medium"
          >
            <T k="home.viewAllPosts" /> <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
